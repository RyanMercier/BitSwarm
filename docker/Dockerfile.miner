# Miner image: every language toolchain + the agent.
#
# Pre-build the base once:
#   docker build -f docker/Dockerfile.base -t bitswarm-base:latest .
#
# Then docker-compose / docker build picks up this thin layer.
FROM bitswarm-base:latest

WORKDIR /app

# Source code goes in last so iterating on miner code reuses every
# toolchain layer.
COPY miner/ ./miner/
COPY protocol/ ./protocol/
COPY validator/ ./validator/
COPY config.py .

# Default backend: claude_code (works with mounted ~/.claude/.credentials.json).
# Override per-miner via docker-compose env to pick "sdk", "openai", etc.
ENV MINER_HOST=0.0.0.0 \
    MINER_PORT=8081 \
    MINER_BACKEND=claude_code

EXPOSE 8081
CMD ["python", "-m", "miner.server"]
