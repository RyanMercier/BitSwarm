# Validator image: all toolchains (validator runs cross-compile +
# integration tests + repair miners, so needs every language toolchain
# the miners do).
#
# Pre-build the base once:
#   docker build -f docker/Dockerfile.base -t bitswarm-base:latest .
FROM bitswarm-base:latest

WORKDIR /app

COPY validator/ ./validator/
COPY miner/ ./miner/
COPY protocol/ ./protocol/
COPY config.py .

ENV VALIDATOR_HOST=0.0.0.0 \
    VALIDATOR_PORT=8080 \
    COORDINATOR_BACKEND=claude_code

EXPOSE 8080
CMD ["python", "-m", "validator.server"]
